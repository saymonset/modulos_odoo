<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_collective_agreement_assign_wizard" model="ir.ui.view">
        <field name="name">collective.agreement.assign.wizard.form</field>
        <field name="model">collective.agreement.assign.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Collective Agreements">
                <group>
                    <field name="partner_id" />
                    <field
                        name="collective_agreement_ids"
                        widget="many2many_tags"
                        options="{'no_create': True}"
                    />
                </group>
                <footer>
                    <button
                        string="Assign"
                        type="object"
                        name="action_assign"
                        class="btn-primary"
                    />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record
        id="action_collective_agreement_assign_wizard"
        model="ir.actions.act_window"
    >
        <field name="name">Assign Collective Agreements</field>
        <field name="res_model">collective.agreement.assign.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
