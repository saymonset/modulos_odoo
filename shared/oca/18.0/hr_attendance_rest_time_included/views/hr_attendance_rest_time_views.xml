<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_attendance_rest_time_tree" model="ir.ui.view">
        <field name="name">hr.attendance.rest_time.tree</field>
        <field name="model">hr.attendance.rest_time</field>
        <field name="arch" type="xml">
            <list edit="0" sample="1">
                <field name="employee_id" />
                <field name="check_in" />
                <field name="check_out" />
                <field name="worked_hours" string="Rest Hours" widget="float_time" />
            </list>
        </field>
    </record>

    <record id="hr_attendance_rest_time_view_form" model="ir.ui.view">
        <field name="name">hr.attendance.rest_time.form</field>
        <field name="model">hr.attendance.rest_time</field>
        <field name="arch" type="xml">
            <form string="Employee rest time" edit="0">
                <sheet>
                    <group>
                        <field name="employee_id" />
                        <field name="check_in" />
                        <field name="check_out" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
