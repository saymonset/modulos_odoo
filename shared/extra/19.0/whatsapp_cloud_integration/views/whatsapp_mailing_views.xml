<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_whatsapp_mailing" model="ir.actions.act_window">
        <field name="name">Campañas WhatsApp</field>
        <field name="res_model">whatsapp.mailing</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_whatsapp_mailing_form" model="ir.ui.view">
        <field name="name">whatsapp.mailing.form</field>
        <field name="model">whatsapp.mailing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_mailing" type="object" string="Enviar" class="btn-primary" 
                            invisible="state not in ['draft']"/>
                    <field name="state" widget="badge"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre interno..."/></h1>
                    </div>
                    <group>
                        <field name="subject" required="1"/>
                        <field name="partner_ids" widget="many2many_tags"/>
                        <field name="schedule_type" widget="radio"/>
                        <field name="scheduled_date" invisible="schedule_type != 'later'" required="schedule_type == 'later'"/>
                    </group>
                    <group string="Contenido del Mensaje de WhatsApp">
                        <field name="use_template"/>
                        <field name="campaign_whatsapp_template_id" invisible="not use_template" required="use_template"/>
                        <field name="whatsapp_text" widget="html" placeholder="Texto libre" invisible="use_template"/>
                        <field name="whatsapp_media_url" placeholder="URL de video/imagen" invisible="use_template"/>
                    </group>
                    <!-- Widget dinámico – ahora funciona correctamente -->
                    <field name="parameter_values" 
                           widget="dynamic_parameters" 
                           invisible="not use_template"
                           nolabel="1"
                           help="Parámetros dinámicos de la plantilla"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_mailing_list" model="ir.ui.view">
        <field name="name">whatsapp.mailing.list</field>
        <field name="model">whatsapp.mailing</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject"/>
                <field name="state" widget="badge"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
</odoo>