<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción de ventana para WABA Accounts -->
    <record id="action_waba_account" model="ir.actions.act_window">
        <field name="name">WhatsApp Business Accounts</field>
        <field name="res_model">waba.account</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your WhatsApp Business Account credentials.
            </p>
            <p>
                Store the Phone Number ID, Access Token, and Webhook Verify Token to enable communication with Meta's Cloud API.
            </p>
        </field>
    </record>

    <!-- Vista list (antes list) -->
    <record id="view_waba_account_list" model="ir.ui.view">
        <field name="name">waba.account.list</field>
        <field name="model">waba.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone_number"/>
                <field name="phone_number_id"/>
                <field name="business_account_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Vista form -->
    <record id="view_waba_account_form" model="ir.ui.view">
        <field name="name">waba.account.form</field>
        <field name="model">waba.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Account Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Credentials">
                            <field name="phone_number" placeholder="+1 555 190 5155"/>
                            <field name="phone_number_id" placeholder="1062113076989009"/>
                            <field name="access_token" password="True"/>
                            <field name="business_account_id" placeholder="1634570824541885"/>
                            <field name="verify_token" placeholder="my_secure_token"/>
                        </group>
                        <group string="Configuration">
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <div class="oe_button_box" name="button_box">
                        <button name="button_test_connection" type="object" class="oe_highlight" string="Test Connection"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista search -->
    <record id="view_waba_account_search" model="ir.ui.view">
        <field name="name">waba.account.search</field>
        <field name="model">waba.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone_number"/>
                <field name="phone_number_id"/>
                <separator/>
                <filter string="My Company" name="my_company" domain="[('company_id', 'in', [company_id, False])]"/>
            </search>
        </field>
    </record>
</odoo>