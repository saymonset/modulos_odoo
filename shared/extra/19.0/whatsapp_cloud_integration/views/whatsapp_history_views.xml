<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_whatsapp_history" model="ir.actions.act_window">
        <field name="name">Historial de WhatsApp</field>
        <field name="res_model">whatsapp.history</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Registro de mensajes enviados y recibidos.</p>
        </field>
    </record>

    <record id="view_whatsapp_history_list" model="ir.ui.view">
        <field name="name">whatsapp.history.list</field>
        <field name="model">whatsapp.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="partner_id"/>
                <field name="direction" widget="badge" decoration-success="direction == 'outgoing'" decoration-info="direction == 'incoming'"/>
                <field name="message_body" string="Mensaje"/>
                <field name="status" widget="badge"/>
                <field name="message_id"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_history_form" model="ir.ui.view">
        <field name="name">whatsapp.history.form</field>
        <field name="model">whatsapp.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="partner_id"/>
                        <field name="waba_account_id"/>
                        <field name="direction"/>
                        <field name="status"/>
                        <field name="message_id"/>
                        <field name="recipient_number"/>
                        <field name="template_name"/>
                        <field name="message_body" widget="ace" options="{'mode': 'json'}"/>
                        <field name="response_data" widget="ace" options="{'mode': 'json'}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>