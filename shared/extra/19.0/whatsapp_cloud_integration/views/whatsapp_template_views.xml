<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_whatsapp_template" model="ir.actions.act_window">
        <field name="name">Plantillas WhatsApp</field>
        <field name="res_model">whatsapp.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Define aquí las plantillas que has creado y aprobado en Meta (Business Manager).</p>
            <p>El nombre técnico debe coincidir exactamente con el que registraste en Meta.</p>
        </field>
    </record>

    <record id="view_whatsapp_template_list" model="ir.ui.view">
        <field name="name">whatsapp.template.list</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="friendly_name"/>
                <field name="name"/>
                <field name="language_code"/>
                <field name="parameter_count"/>
                <field name="has_video_header"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_template_form" model="ir.ui.view">
        <field name="name">whatsapp.template.form</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="friendly_name" placeholder="Nombre para mostrar..."/></h1>
                    </div>
                    <group>
                        <field name="name" required="1" placeholder="nombre_tecnico_plantilla"/>
                        <field name="language_code"/>
                        <field name="has_video_header"/>
                        <field name="parameter_schema" widget="ace" options="{'mode': 'json'}" 
                               placeholder='{"1": "nombre_cliente", "2": "fecha_cita"}'/>
                        <div class="alert alert-info" role="alert" style="margin-top: 5px; margin-bottom: 5px;">
                            <i class="fa fa-info-circle"></i> 
                            <strong>¿Cómo usar el esquema de parámetros?</strong><br/>
                            • <strong>Sin parámetros:</strong> Deja el campo vacío o escribe <code>{}</code><br/>
                            • <strong>Un parámetro (texto):</strong> <code>{"1": "nombre_cliente"}</code><br/>
                            • <strong>Para plantillas con video (encabezado activado):</strong> El primer parámetro debe ser la URL del video: <code>{"1": "url_video"}</code><br/>
                            • <strong>Varios parámetros:</strong> <code>{"1": "nombre", "2": "producto", "3": "precio"}</code><br/>
                            La <strong>clave</strong> (1,2,3...) es el número de la variable en Meta (<code>{{1}}</code>, <code>{{2}}</code>).<br/>
                            El <strong>valor</strong> es solo una etiqueta interna para recordar qué significa cada parámetro.
                        </div>
                        <field name="parameter_count" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_template_search" model="ir.ui.view">
        <field name="name">whatsapp.template.search</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="friendly_name"/>
                <field name="name"/>
                <separator/>
                <filter name="active" string="Activas" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>
</odoo>