<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción server para enviar mensaje desde el botón de partner -->
    <record id="ir_action_send_whatsapp_from_partner" model="ir.actions.server">
        <field name="name">Enviar mensaje WhatsApp</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
            action = {
                'type': 'ir.actions.act_window',
                'res_model': 'whatsapp.message.wizard',
                'view_mode': 'form',
                'target': 'new',
                'context': {
                    'default_partner_id': record.id,
                }
            }
        </field>
    </record>

    <!-- Cron inactivo (sin numbercall ni doall) -->
    <record id="cron_check_whatsapp" model="ir.cron">
        <field name="name">Sincronización manual de mensajes WhatsApp</field>
        <field name="model_id" ref="model_waba_account"/>
        <field name="state">code</field>
        <field name="code">model._check_incoming_messages()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="active">False</field>
    </record>
</odoo>