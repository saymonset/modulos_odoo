<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_lead_asignado" model="mail.template">
            <field name="name">Nuevo Lead Asignado - Chatbot UNISA</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="email_from">{{object.user_id.email or ''}}</field>
            <field name="partner_to">{{object.user_id.partner_id.id}}</field>
            <field name="subject">Nuevo lead asignado: {{object.name}}</field>
            <field name="body_html"><![CDATA[
<p>Hola <t-esc="object.user_id.partner_id.name"/>,</p>
<p>Se te ha asignado un nuevo lead generado desde el chatbot de UNISA.</p>
<br/>
<p><strong>Datos del paciente:</strong></p>
<ul>
    <li><strong>Nombre:</strong> <t-esc="object.contact_name"/></li>
    <li><strong>Teléfono:</strong> <t-esc="object.phone"/></li>
    <li><strong>Email:</strong> <t-esc="object.email_from"/></li>
    <li><strong>Servicio:</strong> <t-esc="object.name.split(' - ')[0] if ' - ' in object.name else object.name"/></li>
    <li><strong>Equipo:</strong> <t-esc="object.team_id.name if object.team_id else 'Sin equipo'"/></li>
</ul>
<br/>
<p><strong>Descripción:</strong></p>
<p t-esc="object.description"/>
<br/>
<p>Por favor, contacta al paciente a la brevedad para dar seguimiento a su solicitud.</p>
<p>Saludos,</p>
<p><strong>Sistema UNISA Salud</strong></p>
            ]]></field>
        </record>
    </data>
</odoo>
