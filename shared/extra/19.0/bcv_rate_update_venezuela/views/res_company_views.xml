<odoo>
    <record id="view_company_form_inherit_schedule" model="ir.ui.view">
        <field name="name">res.company.form.inherit.schedule</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Horario de Atención">
                    <group>
                        <field name="schedule_info" placeholder="Ej. Lunes a Viernes 9am a 6pm, Sábados 9am a 1pm"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>