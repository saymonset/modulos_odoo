<odoo>
    <record id="view_company_form_inherit_schedule" model="ir.ui.view">
        <field name="name">res.company.form.inherit.schedule</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Horario de Atención">
                    <group>
                        <field name="schedule_info" placeholder="Ej. Lunes a Viernes 9am a 6pm, Sábados 9am a 1pm"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <record id="view_company_form_inherit_bcv_manual" model="ir.ui.view">
        <field name="name">res.company.form.inherit.bcv.manual</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Tasa BCV Manual">
                    <group>
                        <field name="bcv_manual_rate_active"/>
                        <field name="bcv_manual_rate"
                               invisible="not bcv_manual_rate_active"
                               required="bcv_manual_rate_active"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    <record id="view_company_form_inherit_cop" model="ir.ui.view">
        <field name="name">res.company.form.inherit.cop</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Peso Colombiano (COP)">
                    <group string="Visibilidad">
                        <field name="cop_show_fields"/>
                    </group>
                    <group string="Tasa Manual COP">
                        <field name="cop_manual_rate_active"/>
                        <field name="cop_manual_rate"
                               invisible="not cop_manual_rate_active"
                               required="cop_manual_rate_active"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>