<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista tree base (lista simple) con Total USD -->
    <record id="purchase_order_tree_view_usd" model="ir.ui.view">
        <field name="name">purchase.order.tree.usd.total</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="amount_total_usd" string="Total USD" sum="Total USD" widget="monetary" options="{'currency_field': 'currency_aux'}"/>
            </xpath>
        </field>
    </record>

    <!-- Vista tree KPIs (dashboard de solicitudes) con Total USD -->
    <record id="purchase_order_kpis_tree_view_usd" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.usd.total</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="amount_total_usd" string="Total USD" sum="Total USD" widget="monetary" options="{'currency_field': 'currency_aux'}"/>
            </xpath>
        </field>
    </record>

    <!-- Vista form: columnas USD en líneas + Total USD -->
    <record id="purchase_order_form_view_usd" model="ir.ui.view">
        <field name="name">purchase.order.form.usd.total</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- Columnas en las líneas -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="before">
                <field name="rate_value" string="Tasa BCV" readonly="1" optional="hide"/>
                <field name="price_subtotal_usd_bcv" string="Subtotal USD" readonly="1"/>
            </xpath>
            <!-- Total USD en el footer -->
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="inside">
                <div style="display:flex; align-items:center; gap:5px;" class="mt-2">
                    <label for="amount_total_usd" string="Total USD (BCV)" style="font-weight:bold; color:green;"/>
                    <field name="amount_total_usd" readonly="1" style="font-weight:bold; color:green;" widget="monetary" options="{'currency_field': 'currency_aux'}"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
