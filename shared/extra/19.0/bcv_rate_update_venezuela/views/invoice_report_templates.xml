<odoo>
    <template id="report_invoice_document_inherit_bcv" inherit_id="account.report_invoice_document">
        <xpath expr="//table[@name='invoice_line_table']/thead/tr/th[@name='th_subtotal']" position="after">
            <th name="th_price_usd" class="text-end text-nowrap">Precio USD</th>
            <th name="th_rate" class="text-end text-nowrap">Tasa BCV (USD/VES)</th>
            <th name="th_subtotal_usd" class="text-end text-nowrap">Subtotal USD</th>
            <t t-if="o.company_id.cop_show_fields">
                <th name="th_rate_cop" class="text-end text-nowrap">Tasa COP</th>
                <th name="th_subtotal_cop" class="text-end text-nowrap">Subtotal COP</th>
            </t>
        </xpath>

        <xpath expr="//td[@name='td_subtotal']" position="after">
            <td name="td_price_usd" class="text-end text-nowrap">
                <span t-if="line.price_usd_bcv" t-esc="line.price_usd_bcv" t-options="{'widget': 'monetary', 'display_currency': env.ref('base.USD', raise_if_not_found=False)}"/>
            </td>
            <td name="td_rate" class="text-end text-nowrap">
                <span t-if="line.bcv_rate_value" t-esc="'{:,.2f}'.format(line.bcv_rate_value)"/>
            </td>
            <td name="td_subtotal_usd" class="text-end o_price_total">
                <span t-if="line.price_subtotal_usd_bcv" t-esc="line.price_subtotal_usd_bcv" t-options="{'widget': 'monetary', 'display_currency': env.ref('base.USD', raise_if_not_found=False)}"/>
            </td>
            <t t-if="o.company_id.cop_show_fields">
                <td name="td_rate_cop" class="text-end text-nowrap">
                    <span t-if="line.cop_rate_value" t-esc="'{:,.2f}'.format(line.cop_rate_value)"/>
                </td>
                <td name="td_subtotal_cop" class="text-end o_price_total">
                    <span t-if="line.price_subtotal_cop" t-esc="line.price_subtotal_cop" t-options="{'widget': 'monetary', 'display_currency': env.ref('base.COP', raise_if_not_found=False) or env['res.currency'].sudo().search([('name','=','COP')], limit=1)}"/>
                </td>
            </t>
        </xpath>

        <xpath expr="//div[@id='right-elements']" position="inside">
            <div class="text-end mt-2">
                <strong style="color:green;">Total USD ($): </strong>
                <span t-if="o.amount_total_usd" t-esc="o.amount_total_usd" t-options="{'widget': 'monetary', 'display_currency': env.ref('base.USD', raise_if_not_found=False)}" style="font-weight:bold; color:green;"/>
            </div>
            <div class="text-end mt-2">
                <strong>Tasa de Cambio (Bs.): </strong>
                <span t-if="o.bcv_rate_value" t-esc="'%s Bs.' % '{:,.2f}'.format(o.bcv_rate_value)" style="font-weight:bold;"/>
            </div>
            <div class="text-end mt-2">
                <strong style="color:green;">Total Bolívares (VES): </strong>
                <span t-if="o.amount_total_ves_from_usd" t-esc="o.amount_total_ves_from_usd" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" style="font-weight:bold; color:green;"/>
            </div>
            <t t-if="o.company_id.cop_show_fields">
                <div class="text-end mt-2">
                    <strong style="color:blue;">Total COP: </strong>
                    <span t-if="o.amount_total_cop" t-esc="o.amount_total_cop" t-options="{'widget': 'monetary', 'display_currency': env.ref('base.COP', raise_if_not_found=False) or env['res.currency'].sudo().search([('name','=','COP')], limit=1)}" style="font-weight:bold; color:blue;"/>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
