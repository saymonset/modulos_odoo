<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. Formulario de Plantilla de Producto (Product Template) -->
    <record id="product_template_form_view_usd" model="ir.ui.view">
        <field name="name">product.template.form.usd.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="list_price" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <xpath expr="//div[@name='list_price_uom']/field[@name='list_price']" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;">o</span>
                <field name="list_price_usd"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="not company_id.cop_show_fields">o</span>
                <field name="list_price_cop"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not company_id.cop_show_fields"/>
                <span class="text-muted small mx-1" invisible="not company_id.cop_show_fields">COP</span>
            </xpath>
            <field name="standard_price" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;">o</span>
                <field name="standard_price_usd"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="not company_id.cop_show_fields">o</span>
                <field name="standard_price_cop"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not company_id.cop_show_fields"/>
                <span class="text-muted small mx-1" invisible="not company_id.cop_show_fields">COP</span>
            </field>
        </field>
    </record>

    <!-- 2. Formulario de Variante de Producto (Product Product) -->
    <record id="product_product_form_view_usd" model="ir.ui.view">
        <field name="name">product.product.form.usd.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <field name="lst_price" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="lst_price" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="product_variant_count &gt; 1">o</span>
                <field name="lst_price_usd"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       readonly="product_variant_count &gt; 1"/>
                <field name="currency_cop_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="product_variant_count &gt; 1 or not company_id.cop_show_fields">o</span>
                <field name="lst_price_cop"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not company_id.cop_show_fields"
                       readonly="product_variant_count &gt; 1"/>
                <span class="text-muted small mx-1" invisible="not company_id.cop_show_fields or product_variant_count &gt; 1">COP</span>
                <div class="text-warning small mt-1" invisible="product_variant_count &lt;= 1">
                    Para precios distintos por variante, usa <strong>Precio Extra USD</strong> en <strong>Atributos y Variantes</strong>.
                </div>
            </field>
            <field name="standard_price" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;">o</span>
                <field name="standard_price_usd"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="not company_id.cop_show_fields">o</span>
                <field name="standard_price_cop"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not company_id.cop_show_fields"/>
                <span class="text-muted small mx-1" invisible="not company_id.cop_show_fields">COP</span>
            </field>
        </field>
    </record>

    <!-- 3. Formulario Rápido de Variante de Producto (Easy Edit Form) -->
    <record id="product_variant_easy_edit_view_usd" model="ir.ui.view">
        <field name="name">product.product.variant.easy.edit.usd.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="arch" type="xml">
            <field name="lst_price" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="lst_price" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="product_variant_count &gt; 1">o</span>
                <field name="lst_price_usd"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       readonly="product_variant_count &gt; 1"/>
                <field name="currency_cop_id" invisible="1"/>
                <span class="mx-2" style="font-weight: bold;" invisible="product_variant_count &gt; 1 or not company_id.cop_show_fields">o</span>
                <field name="lst_price_cop"
                       class="oe_inline"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not company_id.cop_show_fields"
                       readonly="product_variant_count &gt; 1"/>
                <span class="text-muted small mx-1" invisible="not company_id.cop_show_fields or product_variant_count &gt; 1">COP</span>
                <div class="text-warning small mt-1" invisible="product_variant_count &lt;= 1">
                    Para precios distintos por variante, usa <strong>Precio Extra USD</strong> en <strong>Atributos y Variantes</strong>.
                </div>
            </field>
        </field>
    </record>

    <!-- 4. Lista de Valores de Atributo de Variantes (Attribute Values Tree) -->
    <record id="product_template_attribute_value_view_tree_inherit" model="ir.ui.view">
        <field name="name">product.template.attribute.value.view.list.inherit</field>
        <field name="model">product.template.attribute.value</field>
        <field name="inherit_id" ref="product.product_template_attribute_value_view_tree"/>
        <field name="arch" type="xml">
            <field name="price_extra" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="price_extra" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="price_extra_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="price_extra_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
            </field>
        </field>
    </record>

    <!-- 6. Vista de lista de Plantillas de Producto (Product Template Tree) -->
    <record id="product_template_tree_view_usd" model="ir.ui.view">
        <field name="name">product.template.tree.usd.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="list_price" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="list_price" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="list_price_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="list_price_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
            </field>
        </field>
    </record>

    <!-- 7. Vista de lista de Variantes de Producto (Product Product Tree) -->
    <record id="product_product_tree_view_usd" model="ir.ui.view">
        <field name="name">product.product.tree.usd.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <field name="lst_price" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="lst_price" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="lst_price_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="lst_price_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
            </field>
        </field>
    </record>

    <!-- 8. Formulario de Valor de Atributo de Variantes (Attribute Value Form) -->
    <record id="product_template_attribute_value_view_form_inherit" model="ir.ui.view">
        <field name="name">product.template.attribute.value.view.form.inherit</field>
        <field name="model">product.template.attribute.value</field>
        <field name="inherit_id" ref="product.product_template_attribute_value_view_form"/>
        <field name="arch" type="xml">
            <field name="price_extra" position="attributes">
                <attribute name="digits">[16, 2]</attribute>
            </field>
            <field name="price_extra" position="after">
                <field name="currency_usd_id" invisible="1"/>
                <field name="price_extra_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" invisible="1"/>
                <field name="price_extra_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       invisible="not product_tmpl_id.company_id.cop_show_fields"/>
                <span class="text-muted small mx-1" invisible="not product_tmpl_id.company_id.cop_show_fields">COP</span>
                <div class="text-warning small mt-1">
                    Para precios distintos por variante, edita <strong>Precio Extra USD</strong> aquí.
                </div>
            </field>
        </field>
    </record>

    <!-- 9. Vista de lista de Productos (Existencias - Stock Report) -->
    <record id="product_product_stock_tree_view_usd" model="ir.ui.view">
        <field name="name">product.product.stock.tree.usd.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_product_stock_tree"/>
        <field name="arch" type="xml">
            <field name="qty_available" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="standard_price_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show"/>
                <field name="total_value_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show" sum="Total Value USD"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="standard_price_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
                <field name="total_value_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide" sum="Total Value COP"/>
            </field>
        </field>
    </record>

    <!-- 10. Vista de lista de Productos a Fecha (Stock at Date) -->
    <record id="product_product_stock_at_date_view_usd" model="ir.ui.view">
        <field name="name">product.product.stock.at.date.usd.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.view_stock_product_tree"/>
        <field name="arch" type="xml">
            <field name="virtual_available" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="standard_price_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show"/>
                <field name="total_value_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"
                       optional="show" sum="Total Value USD"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="standard_price_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
                <field name="total_value_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide" sum="Total Value COP"/>
            </field>
        </field>
    </record>

</odoo>
