<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_purchaseorder_inherit_bcv" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//th[@name='th_subtotal']" position="before">
            <t t-set="usd_currency" t-value="env['res.currency'].search([('name','=','USD')], limit=1)"/>
            <th name="th_rate" class="text-end"><strong>Tasa BCV</strong></th>
            <th name="th_price_usd" class="text-end"><strong>Precio USD</strong></th>
        </xpath>
        <xpath expr="//th[@name='th_subtotal']" position="after">
            <th name="th_subtotal_usd" class="text-end"><strong>Subtotal USD</strong></th>
        </xpath>

        <xpath expr="//td[@id='product']" position="before">
            <td class="text-end">
                <span t-if="line.rate_value" t-esc="'{:,.2f}'.format(line.rate_value)"/>
            </td>
            <td class="text-end">
                <span t-if="line.price_usd_bcv" t-esc="line.price_usd_bcv" t-options="{'widget': 'monetary', 'display_currency': usd_currency}"/>
            </td>
        </xpath>
        <xpath expr="//td[span/@t-field='line.price_subtotal']" position="after">
            <td class="text-end">
                <span t-esc="line.price_subtotal_usd_bcv" t-options="{'widget': 'monetary', 'display_currency': usd_currency}"/>
            </td>
        </xpath>

        <xpath expr="//div[@id='total']" position="inside">
            <div class="text-end mt-2">
                <strong style="color:green;">Total USD (BCV): </strong>
                <span t-if="o.amount_total_usd" t-esc="o.amount_total_usd" t-options="{'widget': 'monetary', 'display_currency': usd_currency}" style="font-weight:bold; color:green;"/>
            </div>
        </xpath>
    </template>

</odoo>
