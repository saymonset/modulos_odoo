<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_quant_tree_view_usd" model="ir.ui.view">
        <field name="name">stock.quant.tree.usd</field>
        <field name="model">stock.quant</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="value_usd"
                       widget="monetary"
                       options="{'currency_field': 'currency_usd_id'}"/>
                <field name="currency_cop_id" column_invisible="True"/>
                <field name="value_cop"
                       widget="monetary"
                       options="{'currency_field': 'currency_cop_id'}"
                       optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>