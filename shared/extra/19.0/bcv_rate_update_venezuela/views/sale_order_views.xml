<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_inherit_partner_phone" model="ir.ui.view">
        <field name="name">sale.order.form.phone</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="partner_phone" readonly="1" string="Teléfono"/>
            </field>
        </field>
    </record>

    <record id="view_order_form_inherit_payment_proof" model="ir.ui.view">
        <field name="name">sale.order.form.payment.proof</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Comprobante de pago">
                    <group>
                        <field name="payment_proof" widget="binary" filename="payment_proof_filename"/>
                        <field name="payment_proof_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="payment_date"/>
                        <field name="payment_method"/>
                        <field name="bank_origin"/>
                        <field name="bank_destination"/>
                        <field name="reference"/>
                        <field name="amount_vef" digits="[12, 2]"/>
                        <field name="exchange_rate" digits="[12, 2]"/>
                        <field name="amount_usd" digits="[12, 2]"/>
                        <field name="amount_cop" digits="[12, 2]" invisible="not company_id.cop_show_fields"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Vista tree (lista de cotizaciones) con Total USD -->
    <record id="sale_order_tree_view_usd" model="ir.ui.view">
        <field name="name">sale.order.tree.usd.total</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="amount_total_usd" string="Total USD" sum="Total USD" optional="show" widget="monetary" options="{'currency_field': 'currency_aux'}"/>
                <field name="amount_total_cop" string="Total COP" optional="hide" widget="monetary" options="{'currency_field': 'currency_aux_cop'}"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_view_usd" model="ir.ui.view">
        <field name="name">sale.order.form.usd.total</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
           <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="before">
                <field name="rate_value" string="Tasa BCV (USD/VES)" readonly="1" optional="show"/>
                <field name="rate_value_cop" string="Tasa COP" readonly="1" optional="hide"/>
                <field name="price_subtotal_usd_bcv" string="Subtotal USD" readonly="1" />
                <field name="price_subtotal_cop" string="Subtotal COP" readonly="1" optional="hide"/>
            </xpath>
          <xpath expr="//group[@name='sale_total']" position="inside">
                <div style="max-width:55%;">
                    <div style="display:flex; align-items:center; gap:5px;">
                        <label for="amount_total_usd" string="Total USD ($)" style="font-weight:bold; color:green;"/>
                        <field name="amount_total_usd" readonly="1" style="font-weight:bold; color:green;" widget="monetary" options="{'currency_field': 'currency_aux'}"/>
                    </div>
                    <div style="display:flex; align-items:center; gap:5px;">
                        <label for="bcv_rate_value" string="Tasa de Cambio (Bs.)" style="font-weight:bold;"/>
                        <field name="bcv_rate_value" readonly="1" style="font-weight:bold;"/>
                        <span class="text-muted small">Bs.</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:5px;">
                        <label for="amount_total_ves_from_usd" string="Total Bolívares (VES)" style="font-weight:bold; color:green;"/>
                        <field name="amount_total_ves_from_usd" readonly="1" style="font-weight:bold; color:green;" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </div>
                    <div style="display:flex; align-items:center; gap:5px;" invisible="not company_id.cop_show_fields">
                        <label for="amount_total_cop" string="Total COP" style="font-weight:bold; color:blue;"/>
                        <field name="amount_total_cop" readonly="1" style="font-weight:bold; color:blue;" widget="monetary" options="{'currency_field': 'currency_aux_cop'}"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
