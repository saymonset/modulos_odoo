<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_currency_rate_provider_tree" model="ir.ui.view">
        <field name="name">currency.rate.provider.tree</field>
        <field name="model">currency.rate.provider</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-danger="state == 'error'">
                <field name="is_main_rate" string="Main" widget="boolean_toggle"/>
                <field name="name"/>
                <field name="provider_type"/>
                <field name="currency_id" string="Target"/>
                <field name="last_rate" string="Rate" widget="monetary" options="{'currency_field': 'rate_currency_id'}"/>
                <field name="rate_currency_id" string="Currency"/>
                <field name="last_update"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_currency_rate_provider_form" model="ir.ui.view">
        <field name="name">currency.rate.provider.form</field>
        <field name="model">currency.rate.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_update_rate" string="Update Now" type="object" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. BCV Venezuela"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="provider_type"/>
                            <field name="currency_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="is_main_rate" widget="boolean_toggle"/>
                            <field name="active"/>
                            <field name="rate_currency_id"/>
                            <field name="last_rate" widget="monetary" options="{'currency_field': 'rate_currency_id'}"/>
                            <field name="last_update"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_currency_rate_provider" model="ir.actions.act_window">
        <field name="name">Rate Providers</field>
        <field name="res_model">currency.rate.provider</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_currency_rate_provider"
              name="Rate Providers"
              parent="account.menu_finance_configuration"
              action="action_currency_rate_provider"
              sequence="20"/>
</odoo>
