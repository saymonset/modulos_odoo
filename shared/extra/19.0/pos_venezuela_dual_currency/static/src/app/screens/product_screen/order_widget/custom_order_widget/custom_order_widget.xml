<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_venezuela_dual_currency.CustomOrderWidget">
        <span class="value me-2">
            Ref: <span class="total fw-bold" t-esc="formatDecimal(getRefTotal())"/>
        </span>
        <span class="value">
            <span class="total" t-esc="formatMonetary((state.taxTotals.order_sign || 0) * (state.taxTotals.order_total || 0), {currencyId: state.taxTotals.currency_id})"/>
        </span>
    </t>
</templates>
