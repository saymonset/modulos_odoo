<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_venezuela_dual_currency.PaymentScreenDueUsd">
        <div class="px-2 py-1">
            <!-- Total en Bs arriba -->
            <div class="d-flex justify-content-between align-items-center small text-muted">
                <span>Total</span>
                <span>Bs. <t t-esc="formatAmount(totalBs)"/></span>
            </div>
            <!-- Total en USD -->
            <div class="d-flex justify-content-between align-items-center small text-muted border-bottom pb-1 mb-1">
                <span>Total $</span>
                <span>$ <t t-esc="formatAmount(totalUsd)"/></span>
            </div>
            <!-- Restante USD: rojo, más grande, arriba -->
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-danger fw-bold">Resta $</span>
                <span class="text-danger fw-bold fs-6">$ <t t-esc="formatAmount(remainingUsd)"/></span>
            </div>
            <!-- Restante Bs: azul, debajo, tamaño normal -->
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-primary fw-bold">Resta Bs.</span>
                <span class="text-primary fw-bold">Bs. <t t-esc="formatAmount(remainingBs)"/></span>
            </div>
            <!-- Restante COP: verde, compacto -->
            <div t-if="showCop" class="d-flex justify-content-between align-items-center border-top pt-1 mt-1 small">
                <span class="text-success fw-bold">Resta COP</span>
                <span class="text-success fw-bold">$ <t t-esc="formatAmount(remainingCop)"/></span>
            </div>
        </div>
    </t>

    <t t-inherit="point_of_sale.PaymentScreenDue" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('total')]" position="after">
            <PaymentScreenDueUsd/>
        </xpath>
    </t>

</templates>
