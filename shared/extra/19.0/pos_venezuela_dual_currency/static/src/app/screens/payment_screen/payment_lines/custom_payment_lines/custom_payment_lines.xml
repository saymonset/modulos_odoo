<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_venezuela_dual_currency.CustomPaymentLines">
        <div class="paymentlines d-flex flex-column overflow-y-auto gap-1">
            <div class="payment-infos d-flex align-items-center justify-content-between flex-grow-1 px-3 py-3 text-truncate cursor-pointer fs-2">
                <span class="payment-name">Bs. → USD</span>
                <div class="payment-amount px-3">
                    <input type="number" t-ref="bsInput"
                           class="form-control border-0 border-bottom"
                           style="border-bottom: 2px solid #000;"
                           placeholder="Monto Bs."
                           t-att-value="state.inputBs"
                           t-on-input="onInputChange"
                           t-on-blur="onBlur"/>
                </div>
            </div>
            <div class="payment-infos d-flex align-items-center justify-content-between flex-grow-1 px-3 py-3 text-truncate cursor-pointer fs-2">
                <span class="payment-name">USD</span>
                <div class="payment-amount px-3">
                    <t t-esc="formatDecimal(state.resultUsd)"/>
                </div>
            </div>
        </div>
    </t>
</templates>
