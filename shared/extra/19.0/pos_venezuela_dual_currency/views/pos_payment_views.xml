<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_payment_tree_inherit" model="ir.ui.view">
        <field name="name">pos.payment.tree.foreign.currency</field>
        <field name="model">pos.payment</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_payment_tree"/>
        <field name="arch" type="xml">
            <field name="amount" position="after">
                <field name="currency_type" optional="show"/>
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="amount_foreign" optio0nal="show" widget="monetary" options="{'currency_field': 'currency_usd_id'}"/>
                <field name="rate_applied" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_pos_order_form_inherit_payment" model="ir.ui.view">
        <field name="name">pos.order.form.payment.foreign.currency</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_ids']/list/field[@name='amount']" position="after">
                <field name="currency_type" optional="show"/>
                <field name="currency_usd_id" column_invisible="True"/>
                <field name="amount_foreign" optional="show" widget="monetary" options="{'currency_field': 'currency_usd_id'}"/>
                <field name="rate_applied" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
