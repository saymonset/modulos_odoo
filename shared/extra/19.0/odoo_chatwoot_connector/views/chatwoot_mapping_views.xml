<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_chatwoot_mapping_tree" model="ir.ui.view">
    <field name="name">chatwoot.mapping.tree</field>
    <field name="model">chatwoot.mapping</field>
      <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="team_id"/>
        <field name="equipo_asignado"/>
        <field name="chatwoot_inbox_id"/>
        <field name="chatwoot_agent_id"/>
        <field name="chatwoot_agent_email"/>
        <field name="prefer_assign_to_agent"/>
        <field name="chatwoot_tags"/>
      </list>
    </field>
  </record>

  <record id="view_chatwoot_mapping_form" model="ir.ui.view">
    <field name="name">chatwoot.mapping.form</field>
    <field name="model">chatwoot.mapping</field>
    <field name="arch" type="xml">
      <form string="Chatwoot Mapping">
        <sheet>
          <div class="alert alert-info" role="alert">
            <strong>Guía rápida:</strong>
            <span> llena primero <em>Name</em>, luego elige <em>Equipo Asignado</em> de la lista, después el <em>Equipo CRM</em> y por último el <em>Chatwoot inbox id</em>. No escribas valores nuevos para Equipo Asignado.</span>
          </div>
          <group>
            <group string="Identificación">
              <field name="name" placeholder="Ej: Citas Medios Propios"/>
              <field name="flow_id" options="{'no_create': True}"/>
              <field name="team_id" options="{'no_create': True}"/>
              <field name="equipo_asignado"/>
            </group>
            <group string="Asignación en Chatwoot">
              <field name="chatwoot_inbox_id" placeholder="Ej: 7"/>
              <field name="chatwoot_agent_id" placeholder="Ej: 9"/>
              <field name="chatwoot_agent_email" placeholder="ejemplo@correo.com"/>
              <field name="prefer_assign_to_agent"/>
              <field name="chatwoot_tags" placeholder="Citas,WhatsApp"/>
            </group>
            <group string="Estado">
              <field name="active"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_chatwoot_mapping" model="ir.actions.act_window">
    <field name="name">Chatwoot Mappings</field>
    <field name="res_model">chatwoot.mapping</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_chatwoot_root" name="Chatwoot" sequence="90"/>
  <menuitem id="menu_chatwoot_config" name="Integración Chatwoot" parent="menu_chatwoot_root" sequence="10"/>
  <menuitem id="menu_chatwoot_mappings" name="Mappings" parent="menu_chatwoot_config" action="action_chatwoot_mapping" sequence="20"/>

</odoo>
