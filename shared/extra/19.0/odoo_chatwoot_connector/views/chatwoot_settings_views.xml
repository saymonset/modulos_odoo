<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Integrate Chatwoot settings into the global Settings form -->
  <record id="view_chatwoot_settings_inherit" model="ir.ui.view">
    <field name="name">chatwoot.settings.inherit</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form" position="inside">
        <group string="Chatwoot Integration">
          <field name="chatwoot_base_url"/>
          <field name="chatwoot_api_token"/>
          <field name="chatwoot_timeout"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
